{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "dynamic-map-renderer-v2.vercel.app" }],
      "destination": "https://www.mappadux.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/player", "destination": "/player.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" }
      ]
    }
  ]
}
